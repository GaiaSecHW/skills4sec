# 应用配置
APP_NAME=SecAgentHub API
APP_VERSION=1.0.0
DEBUG=true

# 数据库配置 (SQLite 开发用)
DATABASE_URL=sqlite://db.sqlite3

# 数据库配置 (MySQL 生产用 / K8s)
# DATABASE_URL=mysql://root:password@mysql:3306/skills4sec

# 数据库配置 (PostgreSQL)
# DATABASE_URL=postgres://user:password@localhost:5432/secagenthub

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=360

# 分页
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Gitea 配置 (用于技能提交工作流)
GITEA_API_URL=http://your-gitea-server:3000/api/v1
GITEA_TOKEN=your-gitea-token
GITEA_REPO=owner/repo
GITEA_SKILLS_BASE_URL=https://your-gitea-server/org-name

# 报告生成 API 配置 (兼容火山引擎/MiniMax 等)
REPORT_API_BASE_URL=https://api.example.com/v1
REPORT_API_KEY=your-report-api-key
REPORT_API_MODEL=model-name

# OpenAI API 配置 (报告生成备用)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 超级管理员配置
SUPER_ADMIN_EMPLOYEE_ID=admin
SUPER_ADMIN_API_KEY=admin123
SUPER_ADMIN_NAME=系统管理员
