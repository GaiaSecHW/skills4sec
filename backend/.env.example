# 应用配置
APP_NAME=SecAgentHub API
APP_VERSION=1.0.0
DEBUG=true

# 数据库配置 (SQLite 开发用)
DATABASE_URL=sqlite://db.sqlite3

# 数据库配置 (PostgreSQL 生产用)
# DATABASE_URL=postgres://user:password@localhost:5432/secagenthub

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 分页
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
