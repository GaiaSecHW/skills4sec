# 应用配置
APP_NAME=SecAgentHub API
APP_VERSION=1.0.0
DEBUG=true

# 数据库配置 (SQLite 开发用)
DATABASE_URL=sqlite://db.sqlite3

# 数据库配置 (PostgreSQL 生产用)
# DATABASE_URL=postgres://user:password@localhost:5432/secagenthub

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=360

# 分页
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Gitea 配置 (用于技能提交工作流)
GITEA_API_URL=http://your-gitea-server:3000/api/v1
GITEA_TOKEN=your-gitea-token
GITEA_REPO=owner/repo
GITEA_SKILLS_BASE_URL=http://your-gitea-server:3000/admin/skills__hub/src/branch/main

# 报告生成 API 配置 (用于技能报告生成)
REPORT_API_KEY=your-api-key
REPORT_API_BASE_URL=https://api.openai.com/v1
REPORT_API_MODEL=gpt-4o

# 超级管理员配置
SUPER_ADMIN_EMPLOYEE_ID=admin
SUPER_ADMIN_API_KEY=admin123
SUPER_ADMIN_NAME=系统管理员

# ICSL 组织同步配置 (用于与 icsl Gitea 组织双向同步 skill)
ICSL_GITEA_API_URL=http://your-gitea-server:3000/api/v1
ICSL_GITEA_TOKEN=your-icsl-gitea-token
ICSL_ORG_NAME=icsl
ICSL_SYNC_INTERVAL=300
ICSL_SYNC_ON_STARTUP=true
# 本地开发用相对路径, K8s 生产环境用 /data (PVC 挂载点)
ICSL_DATA_DIR=./data