  "content": {
    "user_title": "Debug LiveKit and Letta Voice Agents Effectively",
    "value_statement": "Provides a practical debugging reference for LiveKit + Letta voice agents. It resolves common issues like timeouts, audio glitches, and routing failures by enforcing core rules, managing processes, and offering nuclear reset commands to ensure reliable operation.",
    "seo_keywords": [
      "LiveKit",
      "Letta",
      "Voice Agent",
      "Debugging",
      "Process Management",
      "Real-time Audio",
      "WebRTC"
    ],
    "actual_capabilities": [
      "Identify and fix incorrect method overrides (e.g., using llm_node vs generate_reply)",
      "Perform 'nuclear resets' to clear stuck processes and restart services",
      "Diagnose agent liveness using curl and process checks",
      "Troubleshoot WebSocket connection issues (double-slash errors)",
      "Verify Letta routing is active via log markers"
    ],
    "limitations": [
      "Specific to the LiveKit and Letta technology stack",
      "Commands assume a Unix-like environment (bash, pkill)",
      "Hardcoded file paths in reset scripts may require adjustment for different user environments"
    ],
    "use_cases": [
      {
        "target_user": "Voice Agent Developer",
        "title": "Resolving Unresponsive Agents",
        "description": "When a voice agent appears alive but fails to route text or respond, this skill provides the specific checks (like verifying the llm_node hook) to fix the routing logic."
      },
      {
        "target_user": "System Integrator",
        "title": "Recovering from Service Failures",
        "description": "In scenarios of timeouts or audio cutting out due to stuck processes, the 'nuclear reset' script helps kill zombie processes and cleanly restart LiveKit and the agent."
      },
      {
        "target_user": "QA Engineer",
        "title": "Validating Local Environment",
        "description": "Ensures the local testing environment is correctly configured in 'dev' mode and that only one instance of the agent is running to prevent inconsistent behavior."
      }
    ],
    "prompt_templates": [
      {
        "title": "Nuclear Reset",
        "scenario": "The voice agent is stuck, timing out, or behaving erratically.",
        "prompt": "Execute the nuclear reset procedure: kill all letta_voice_agent and livekit-server processes, wait 2 seconds, then restart LiveKit in dev mode and the voice agent in the background."
      },
      {
        "title": "Liveness Check",
        "scenario": "Unsure if the services are running correctly.",
        "prompt": "Check if LiveKit is responding on localhost port 7880 and verify that exactly one letta_voice_agent process is running without duplicates."
      }
    ],
    "output_examples": [
      {
        "input": "Why is my agent not processing text?",
        "output": [
          "Check if you overrode the correct method.",
          "The framework calls llm_node, not generate_reply.",
          "If you overrode the wrong method, your changes won't run."
        ]
      },
      {
        "input": "Audio keeps cutting out during testing.",
        "output": [
          "Check for duplicate voice-agent processes.",
          "Run: ps aux | grep letta_voice_agent",
          "If more than one process exists, kill them all and restart."
        ]
      }
    ],
    "best_practices": [
      "Always override the llm_node method for voice routing, not generate_reply.",
      "Ensure only one voice-agent process runs at a time to avoid conflicts.",
      "Use 'dev' mode for local testing instead of 'start' mode for faster feedback.",
      "Always kill and restart the running process after making code changes."
    ],
    "anti_patterns": [
      "Overriding generate_reply expecting voice routing to work.",
      "Running multiple instances of the voice agent simultaneously.",
      "Using 'start' mode for active local debugging and waiting indefinitely.",
      "Assuming code changes apply without restarting the Python process."
    ],
    "faq": [
      {
        "question": "Why does my agent look alive but never route text?",
        "answer": "You likely overrode the wrong method. The framework calls llm_node, not generate_reply. Ensure your logic is inside llm_node."
      },
      {
        "question": "Why is the audio cutting out or timing out?",
        "answer": "This is commonly caused by duplicate voice-agent processes running. Kill all instances and ensure only one is running."
      },
      {
        "question": "Why aren't my code changes taking effect?",
        "answer": "Edits don't apply until you kill and restart the running process. You might be debugging an old process."
      }
    ]
  },
